# ─────────────────────────────────────────────────────────────────────────────
# secrets.yaml.template — DataPilot Kubernetes Secrets
#
# DO NOT commit the filled-in version to git.
# Generate secrets with:
#   ./scripts/generate-secrets.sh | kubectl apply -f -
#
# Or use External Secrets Operator to pull from AWS Secrets Manager:
#   kubectl apply -f deploy/kubernetes/secrets/external-secrets.yaml
#
# All values must be base64-encoded:
#   echo -n "my-secret-value" | base64
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: datapilot-secrets
  namespace: datapilot
  labels:
    app.kubernetes.io/name: datapilot
    app.kubernetes.io/component: secrets
type: Opaque
data:
  # ── Database ───────────────────────────────────────────────────────────────
  # postgresql+asyncpg://datapilot:<password>@<rds-endpoint>:5432/datapilot
  DATABASE_URL: <base64-encoded-postgresql-url>

  # ── Redis / ElastiCache ────────────────────────────────────────────────────
  # redis://:<auth-token>@<elasticache-endpoint>:6379/0
  REDIS_URL: <base64-encoded-redis-url>

  # ── Kafka / MSK ───────────────────────────────────────────────────────────
  KAFKA_BOOTSTRAP_SERVERS: <base64-encoded-msk-brokers>

  # ── AWS (used only when IRSA is NOT available — e.g. local dev) ───────────
  # In EKS production, leave these empty — IRSA provides credentials via OIDC.
  AWS_ACCESS_KEY_ID: ""
  AWS_SECRET_ACCESS_KEY: ""

  # ── S3 ─────────────────────────────────────────────────────────────────────
  S3_BUCKET_NAME: <base64-encoded-bucket-name>
  S3_REGION: <base64-encoded-region>

  # ── Qdrant ────────────────────────────────────────────────────────────────
  QDRANT_URL: <base64-encoded-qdrant-url>
  QDRANT_API_KEY: <base64-encoded-qdrant-api-key>

  # ── Secret key (FastAPI session signing) ──────────────────────────────────
  SECRET_KEY: <base64-encoded-256bit-random-key>

  # ── Postgres credentials (for Alembic migrations job) ─────────────────────
  POSTGRES_USER: <base64-encoded-username>
  POSTGRES_PASSWORD: <base64-encoded-password>
