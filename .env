# =============================================================================
# DataPilot — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_ENV=development                        # development | staging | production
APP_NAME=DataPilot
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true                            # Hot-reload in development only
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENABLE_SWAGGER=true                        # Disable in production

# -----------------------------------------------------------------------------
# SECRET KEY
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-64-char-string-in-production

# -----------------------------------------------------------------------------
# POSTGRESQL — Metadata store
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=datapilot
POSTGRES_USER=datapilot
POSTGRES_PASSWORD=datapilot_dev_password
DATABASE_URL=postgresql+asyncpg://datapilot:datapilot_dev_password@localhost:5432/datapilot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# REDIS — Cache, sessions, pub/sub, rate limiting
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=86400                   # Default cache TTL: 24 hours
REDIS_SESSION_TTL_SECONDS=604800          # Session TTL: 7 days

# -----------------------------------------------------------------------------
# AWS — General
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                        # Leave blank when using IRSA / instance roles
AWS_SECRET_ACCESS_KEY=                    # Leave blank when using IRSA / instance roles
AWS_SESSION_TOKEN=                        # Leave blank when using IRSA / instance roles

# -----------------------------------------------------------------------------
# AWS BEDROCK — LLM access
# -----------------------------------------------------------------------------
BEDROCK_REGION=us-east-1
BEDROCK_ENDPOINT_URL=                     # Leave blank to use default regional endpoint

# Primary reasoning model (Planner, Orchestrator, Insight, Critic agents)
BEDROCK_MODEL_ID_PRIMARY=anthropic.claude-sonnet-4-5

# Fast/cheap model (Intent, Schema, SQL classification tasks)
BEDROCK_MODEL_ID_FAST=anthropic.claude-haiku-4-5

# Embeddings model (RAG vector indexing)
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Inference parameters
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1
BEDROCK_TOP_P=0.95

# Retry and throttling
BEDROCK_MAX_RETRIES=5
BEDROCK_RETRY_BASE_DELAY_SECONDS=2.0
BEDROCK_RETRY_MAX_DELAY_SECONDS=60.0

# Cost tracking thresholds (USD)
BEDROCK_COST_ALERT_THRESHOLD_PER_SESSION=0.50
BEDROCK_COST_ALERT_THRESHOLD_DAILY=50.00

# IRSA role ARN (leave blank in local dev; set in Kubernetes via service account annotation)
BEDROCK_IRSA_ROLE_ARN=

# -----------------------------------------------------------------------------
# AWS S3 / MINIO — File storage
# -----------------------------------------------------------------------------
S3_BUCKET_NAME=datapilot-datasets-dev
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000     # MinIO local endpoint; blank for real AWS S3
S3_ACCESS_KEY_ID=minioadmin              # MinIO root user; blank when using IAM roles
S3_SECRET_ACCESS_KEY=minioadmin          # MinIO root password; blank when using IAM roles
S3_PRESIGNED_URL_TTL_SECONDS=900         # 15 minutes

# Dataset storage paths
S3_DATASETS_PREFIX=datasets/
S3_REPORTS_PREFIX=reports/
S3_TEMP_PREFIX=tmp/

# -----------------------------------------------------------------------------
# KAFKA — Event streaming
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT        # PLAINTEXT | SSL | SASL_SSL
KAFKA_SASL_MECHANISM=                    # PLAIN | SCRAM-SHA-256 (leave blank for PLAINTEXT)
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_CONSUMER_GROUP_ID=datapilot-analytics-engine
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_MAX_POLL_RECORDS=100

# Topics
KAFKA_TOPIC_DATASET_UPLOADED=dataset.uploaded
KAFKA_TOPIC_SCHEMA_INFERRED=dataset.schema-inferred
KAFKA_TOPIC_DATASET_READY=dataset.ready
KAFKA_TOPIC_PROFILING_COMPLETE=analytics.profiling-complete
KAFKA_TOPIC_CLEANING_COMPLETE=analytics.cleaning-complete
KAFKA_TOPIC_INSIGHT_GENERATED=insight.report-generated
KAFKA_TOPIC_ANOMALY_DETECTED=anomaly.detected
KAFKA_TOPIC_CHAT_MESSAGE=chat.message
KAFKA_TOPIC_AGENT_RESULT=agent.result
KAFKA_TOPIC_AUDIT_EVENTS=audit.events

# -----------------------------------------------------------------------------
# CELERY — Task queue
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300          # 5 minutes soft limit
CELERY_TASK_TIME_LIMIT=600               # 10 minutes hard limit

# -----------------------------------------------------------------------------
# CLICKHOUSE — Analytics store
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=datapilot_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false

# -----------------------------------------------------------------------------
# QDRANT — Vector store
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                          # Leave blank for local unauthenticated instance
QDRANT_COLLECTION_NAME=datapilot_chunks
QDRANT_VECTOR_SIZE=1536                  # Titan Embed v2 dimension
QDRANT_DISTANCE_METRIC=Cosine

# -----------------------------------------------------------------------------
# MINIO — Local S3-compatible object storage (development only)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# ANALYTICS ENGINE
# -----------------------------------------------------------------------------
# DuckDB
DUCKDB_MEMORY_LIMIT=2GB
DUCKDB_THREADS=4

# File size limits
MAX_UPLOAD_SIZE_BYTES=2147483648         # 2 GB
MAX_ROWS_IN_MEMORY=5000000               # 5M rows before switching to streaming

# Anomaly detection
ANOMALY_ZSCORE_THRESHOLD=3.0
ANOMALY_IQR_MULTIPLIER=1.5
ANOMALY_ISOLATION_FOREST_CONTAMINATION=0.05

# Profiling
PROFILING_SAMPLE_SIZE=100000             # Rows sampled for histogram computation
PROFILING_TOP_N_VALUES=20

# -----------------------------------------------------------------------------
# AGENT CONFIGURATION
# -----------------------------------------------------------------------------
AGENT_MAX_RETRIES=3
AGENT_RETRY_BACKOFF_SECONDS=2.0
AGENT_LLM_CACHE_TTL_SECONDS=86400       # Cache LLM responses for 24h

# SQL Agent safety
SQL_AGENT_ROW_LIMIT=10000
SQL_AGENT_TIMEOUT_SECONDS=30

# Python Agent sandboxing
PYTHON_AGENT_TIMEOUT_SECONDS=60
PYTHON_AGENT_MEMORY_LIMIT_MB=512

# RAG
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.72

# Critic Agent
CRITIC_MAX_REVISION_ROUNDS=2

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# PII detection
PII_DETECTION_ENABLED=true
PII_SCORE_THRESHOLD=0.7
PII_REDACTION_PLACEHOLDER=<REDACTED>

# Prompt injection
INJECTION_DETECTION_ENABLED=true
INJECTION_SCORE_THRESHOLD=0.6

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_HOUR=20

# JWT (placeholder — use Vault or Secrets Manager in production)
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------------------
# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=datapilot-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

# Jaeger
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_S3_PREFIX=audit/

# -----------------------------------------------------------------------------
# MLFLOW — Model registry
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=datapilot-forecasting
MLFLOW_S3_ARTIFACT_ROOT=s3://datapilot-datasets-dev/mlflow/

# -----------------------------------------------------------------------------
# FRONTEND (Vite — prefix with VITE_ to expose to browser)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=DataPilot
VITE_APP_ENV=development
VITE_ENABLE_DEVTOOLS=true