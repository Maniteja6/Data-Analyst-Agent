{
  "_comment": "Reference copy of the policy generated by main.tf's aws_iam_policy_document.bedrock_invoke. Terraform renders the live version with model ARNs interpolated from var.allowed_model_ids and var.allowed_inference_profile_ids — this static file exists for security review and for manual `aws iam put-role-policy` application outside Terraform if ever needed. Keep in sync with main.tf if you edit one.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeAllowedModels",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": [
        "arn:aws:bedrock:${aws_region}::foundation-model/anthropic.claude-sonnet-4-5",
        "arn:aws:bedrock:${aws_region}::foundation-model/anthropic.claude-haiku-4-5",
        "arn:aws:bedrock:${aws_region}::foundation-model/amazon.titan-embed-text-v2:0"
      ]
    },
    {
      "Sid": "ListAndDescribeModels",
      "Effect": "Allow",
      "Action": [
        "bedrock:ListFoundationModels",
        "bedrock:GetFoundationModel"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PublishCustomMetrics",
      "Effect": "Allow",
      "Action": "cloudwatch:PutMetricData",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "cloudwatch:namespace": "DataPilot/Bedrock"
        }
      }
    }
  ]
}
